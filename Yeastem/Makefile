# Alternative GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug)
  Lua_config = debug
  Glad_config = debug
  SDL3_config = debug
  ImGui_config = debug
  stb_image_config = debug
  Yeastem_Engine_config = debug
  Yeastem_Editor_config = debug
  Yeastem_Runtime_config = debug
  YSS_Compiler_config = debug

else ifeq ($(config),release)
  Lua_config = release
  Glad_config = release
  SDL3_config = release
  ImGui_config = release
  stb_image_config = release
  Yeastem_Engine_config = release
  Yeastem_Editor_config = release
  Yeastem_Runtime_config = release
  YSS_Compiler_config = release

else ifeq ($(config),dist)
  Lua_config = dist
  Glad_config = dist
  SDL3_config = dist
  ImGui_config = dist
  stb_image_config = dist
  Yeastem_Engine_config = dist
  Yeastem_Editor_config = dist
  Yeastem_Runtime_config = dist
  YSS_Compiler_config = dist

else
  $(error "invalid configuration $(config)")
endif

PROJECTS := Lua Glad SDL3 ImGui stb_image Yeastem\ Engine Yeastem\ Editor Yeastem\ Runtime YSS\ Compiler

.PHONY: all clean help $(PROJECTS) Dependencies

all: $(PROJECTS)

Dependencies: Glad ImGui Lua SDL3 stb_image

Lua:
ifneq (,$(Lua_config))
	@echo "==== Building Lua ($(Lua_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/Lua/Lua -f Makefile config=$(Lua_config)
endif

Glad:
ifneq (,$(Glad_config))
	@echo "==== Building Glad ($(Glad_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/Glad/Glad -f Makefile config=$(Glad_config)
endif

SDL3:
ifneq (,$(SDL3_config))
	@echo "==== Building SDL3 ($(SDL3_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/SDL3/SDL3 -f Makefile config=$(SDL3_config)
endif

ImGui: SDL3
ifneq (,$(ImGui_config))
	@echo "==== Building ImGui ($(ImGui_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/ImGui/ImGui -f Makefile config=$(ImGui_config)
endif

stb_image:
ifneq (,$(stb_image_config))
	@echo "==== Building stb_image ($(stb_image_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/stb_image/stb_image -f Makefile config=$(stb_image_config)
endif

Yeastem\ Engine: SDL3 stb_image Glad Lua ImGui
ifneq (,$(Yeastem_Engine_config))
	@echo "==== Building Yeastem Engine ($(Yeastem_Engine_config)) ===="
	@${MAKE} --no-print-directory -C Yeastem/Engine -f Makefile config=$(Yeastem_Engine_config)
endif

Yeastem\ Editor: Yeastem\ Engine SDL3 ImGui
ifneq (,$(Yeastem_Editor_config))
	@echo "==== Building Yeastem Editor ($(Yeastem_Editor_config)) ===="
	@${MAKE} --no-print-directory -C Yeastem/Editor -f Makefile config=$(Yeastem_Editor_config)
endif

Yeastem\ Runtime: SDL3 Glad
ifneq (,$(Yeastem_Runtime_config))
	@echo "==== Building Yeastem Runtime ($(Yeastem_Runtime_config)) ===="
	@${MAKE} --no-print-directory -C Yeastem/Runtime -f Makefile config=$(Yeastem_Runtime_config)
endif

YSS\ Compiler:
ifneq (,$(YSS_Compiler_config))
	@echo "==== Building YSS Compiler ($(YSS_Compiler_config)) ===="
	@${MAKE} --no-print-directory -C Yeastem/Compiler -f Makefile config=$(YSS_Compiler_config)
endif

clean:
	@${MAKE} --no-print-directory -C Dependancies/Lua/Lua -f Makefile clean
	@${MAKE} --no-print-directory -C Dependancies/Glad/Glad -f Makefile clean
	@${MAKE} --no-print-directory -C Dependancies/SDL3/SDL3 -f Makefile clean
	@${MAKE} --no-print-directory -C Dependancies/ImGui/ImGui -f Makefile clean
	@${MAKE} --no-print-directory -C Dependancies/stb_image/stb_image -f Makefile clean
	@${MAKE} --no-print-directory -C Yeastem/Engine -f Makefile clean
	@${MAKE} --no-print-directory -C Yeastem/Editor -f Makefile clean
	@${MAKE} --no-print-directory -C Yeastem/Runtime -f Makefile clean
	@${MAKE} --no-print-directory -C Yeastem/Compiler -f Makefile clean

