# Alternative GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug)
  Lua_config = debug
  Glad_config = debug
  SDL3_config = debug
  ImGui_config = debug
  stb_image_config = debug
  YeastemEngine_config = debug
  YeastemEditor_config = debug
  YeastemRuntime_config = debug
  YSSCompiler_config = debug

else ifeq ($(config),release)
  Lua_config = release
  Glad_config = release
  SDL3_config = release
  ImGui_config = release
  stb_image_config = release
  YeastemEngine_config = release
  YeastemEditor_config = release
  YeastemRuntime_config = release
  YSSCompiler_config = release

else ifeq ($(config),dist)
  Lua_config = dist
  Glad_config = dist
  SDL3_config = dist
  ImGui_config = dist
  stb_image_config = dist
  YeastemEngine_config = dist
  YeastemEditor_config = dist
  YeastemRuntime_config = dist
  YSSCompiler_config = dist

else
  $(error "invalid configuration $(config)")
endif

PROJECTS := Lua Glad SDL3 ImGui stb_image YeastemEngine YeastemEditor YeastemRuntime YSSCompiler

.PHONY: all clean help $(PROJECTS) Dependencies

all: $(PROJECTS)

Dependencies: Glad ImGui Lua SDL3 stb_image

Lua:
ifneq (,$(Lua_config))
	@echo "==== Building Lua ($(Lua_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/Lua/Lua -f Makefile config=$(Lua_config)
endif

Glad:
ifneq (,$(Glad_config))
	@echo "==== Building Glad ($(Glad_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/Glad/Glad -f Makefile config=$(Glad_config)
endif

SDL3:
ifneq (,$(SDL3_config))
	@echo "==== Building SDL3 ($(SDL3_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/SDL3/SDL3 -f Makefile config=$(SDL3_config)
endif

ImGui: SDL3
ifneq (,$(ImGui_config))
	@echo "==== Building ImGui ($(ImGui_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/ImGui/ImGui -f Makefile config=$(ImGui_config)
endif

stb_image:
ifneq (,$(stb_image_config))
	@echo "==== Building stb_image ($(stb_image_config)) ===="
	@${MAKE} --no-print-directory -C Dependancies/stb_image/stb_image -f Makefile config=$(stb_image_config)
endif

YeastemEngine: SDL3 stb_image Glad Lua ImGui
ifneq (,$(YeastemEngine_config))
	@echo "==== Building YeastemEngine ($(YeastemEngine_config)) ===="
	@${MAKE} --no-print-directory -C Yeastem/Engine -f Makefile config=$(YeastemEngine_config)
endif

YeastemEditor: YeastemEngine SDL3 ImGui
ifneq (,$(YeastemEditor_config))
	@echo "==== Building YeastemEditor ($(YeastemEditor_config)) ===="
	@${MAKE} --no-print-directory -C Yeastem/Editor -f Makefile config=$(YeastemEditor_config)
endif

YeastemRuntime: SDL3 Glad
ifneq (,$(YeastemRuntime_config))
	@echo "==== Building YeastemRuntime ($(YeastemRuntime_config)) ===="
	@${MAKE} --no-print-directory -C Yeastem/Runtime -f Makefile config=$(YeastemRuntime_config)
endif

YSSCompiler:
ifneq (,$(YSSCompiler_config))
	@echo "==== Building YSSCompiler ($(YSSCompiler_config)) ===="
	@${MAKE} --no-print-directory -C Yeastem/Compiler -f Makefile config=$(YSSCompiler_config)
endif

clean:
	@${MAKE} --no-print-directory -C Dependancies/Lua/Lua -f Makefile clean
	@${MAKE} --no-print-directory -C Dependancies/Glad/Glad -f Makefile clean
	@${MAKE} --no-print-directory -C Dependancies/SDL3/SDL3 -f Makefile clean
	@${MAKE} --no-print-directory -C Dependancies/ImGui/ImGui -f Makefile clean
	@${MAKE} --no-print-directory -C Dependancies/stb_image/stb_image -f Makefile clean
	@${MAKE} --no-print-directory -C Yeastem/Engine -f Makefile clean
	@${MAKE} --no-print-directory -C Yeastem/Editor -f Makefile clean
	@${MAKE} --no-print-directory -C Yeastem/Runtime -f Makefile clean
	@${MAKE} --no-print-directory -C Yeastem/Compiler -f Makefile clean

